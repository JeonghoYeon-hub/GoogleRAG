{
  "name": "myrag",
  "version": "1.2.0",
  "description": "File RAG Search System",
  "main": "main.js",
  "scripts": {
    "start": "node server/index.js",
    "electron:dev": "electron .",
    "dist": "electron-builder --win zip --x64"
  },
  "dependencies": {
    "@notionhq/client": "^2.2.15",
    "better-sqlite3": "^12.4.1",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "googleapis": "^142.0.0",
    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.myrag.app",
    "productName": "MYRAG",
    "directories": {
      "output": "dist/electron"
    },
    "files": [
      "main.js",
      "server/**",
      "static/**",
      "package.json",
      "!node_modules/.cache/**",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme,LICENSE,license,LICENCE}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples,__mocks__}",
      "!**/node_modules/**/*.{ts,map,tgz}",
      "!**/node_modules/.bin",
      "!dist/**",
      "!_svg_debug/**",
      "!sessions.db*",
      "!.env*",
      "!client_secret.json",
      "!*.bat",
      "!*.md",
      "!.claude/**",
      "!.git/**"
    ],
    "asar": true,
    "asarUnpack": [
      "static/**",
      "**/node_modules/better-sqlite3/**"
    ],
    "compression": "maximum",
    "win": {
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
